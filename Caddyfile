# ============================================================
# Afterglow by Kevin — Configuration Caddy
# afterglowbykevin.ch
#
# Installation sur le VPS (une seule fois) :
#   sudo cp Caddyfile /etc/caddy/Caddyfile
#   sudo caddy validate --config /etc/caddy/Caddyfile
#   sudo systemctl reload caddy
#
# Caddy gère le HTTPS automatiquement (Let's Encrypt) — aucun chemin de
# certificat à indiquer. Adapter la version PHP-FPM si besoin (php8.3).
# ============================================================

afterglowbykevin.ch {
	root * /var/www/afterglow
	encode gzip zstd

	# --- En-têtes de sécurité ---
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options    "nosniff"
		Referrer-Policy           "strict-origin-when-cross-origin"
		X-Frame-Options           "SAMEORIGIN"
		Permissions-Policy        "camera=(), microphone=(), geolocation=()"
		-Server

		# CSP en mode ENFORCE (bloque les ressources non autorisées).
		# React est auto-hébergé ; 'unsafe-inline' reste nécessaire pour le
		# splash inline (script) et les styles React. Vérifié : Google Fonts,
		# data: (favicon SVG + previews image-slot), POST same-origin (contact).
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"
	}

	# --- Blocage des fichiers sensibles (404, jamais téléchargeables) ---
	# NB : .image-slots.state.json DOIT rester servi (images), donc on ne
	# bloque pas tous les .json — uniquement les fichiers réellement privés.
	@blocked {
		path /.git* /.env* /smtp-config.php /composer.json /composer.lock
		path /contact-log.csv *.csv *.md *.jsx /vendor/* /.github/*
		path /package.json /package-lock.json /scripts/*
	}
	respond @blocked 404

	# --- PHP (formulaire de contact) ---
	php_fastcgi unix//run/php/php8.3-fpm.sock

	# --- Cache long pour les assets statiques ---
	@static {
		path *.css *.js *.webp *.jpg *.jpeg *.png *.gif *.svg *.ico *.woff *.woff2
	}
	header @static Cache-Control "public, max-age=2592000, immutable"

	# --- URLs propres (/mariages → mariages.html), sinon vrai 404 ---
	try_files {path} {path}.html {path}/
	file_server

	# --- Page 404 personnalisée (uniquement les 404, pas les erreurs PHP) ---
	handle_errors 404 {
		rewrite * /404.html
		file_server
	}
}
